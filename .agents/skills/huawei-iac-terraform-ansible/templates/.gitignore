# Local .terraform directories
**/.terraform/*
.terraform
.terraform.lock.hcl

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files — they may contain sensitive data
# Uncomment the line below to enforce:
# *.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore binaries
*.exe

# Ansible
*.retry
ansible/inventory/hosts.yml.bak
